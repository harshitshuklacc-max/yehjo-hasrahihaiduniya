# Production (Vercel + Neon / Vercel Postgres) — required for deploy
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Local only: use the same Neon URLs above, or keep a separate Neon "dev" branch.
# SQLite (file:./dev.db) does NOT work on Vercel.

JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
