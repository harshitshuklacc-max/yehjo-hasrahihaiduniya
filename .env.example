# Production (Vercel + Neon) — BOTH are required for deploy
# Pooled URL (contains "-pooler" in host) — used at runtime by the app
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Direct URL (NO pooler) — required for prisma db push during Vercel build
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Local only: use the same Neon URLs above, or keep a separate Neon "dev" branch.
# SQLite (file:./dev.db) does NOT work on Vercel.

JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
